rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'admin@poar.com';
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function ownsEmail(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    match /services/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /products/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /promotions/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /siteConfig/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /availability/{id} { allow read: if true; allow write: if isAdmin(); }
    match /blockedDates/{id} { allow read: if true; allow write: if isAdmin(); }

    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read:   if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /bookings/{id} {
      allow read:   if isAdmin() || ownsEmail(resource.data.clientEmail);
      allow create: if isSignedIn()
                    && request.resource.data.clientEmail == request.auth.token.email
                    && request.resource.data.status == 'pendente';
      allow update: if isAdmin()
                    || (ownsEmail(resource.data.clientEmail)
                        && request.resource.data.status == 'cancelado');
      allow delete: if isAdmin();
    }

    match /productOrders/{id} {
      allow read:   if isAdmin() || ownsEmail(resource.data.clientEmail);
      allow create: if isSignedIn()
                    && request.resource.data.clientEmail == request.auth.token.email;
      allow update: if isAdmin()
                    || (ownsEmail(resource.data.clientEmail)
                        && request.resource.data.status == 'cancelado');
      allow delete: if isAdmin();
    }

    match /promotionRedemptions/{id} {
      allow read:   if isAdmin() || ownsEmail(resource.data.clientEmail);
      allow create: if isSignedIn()
                    && request.resource.data.clientEmail == request.auth.token.email;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /agendaAlerts/{id} {
      allow read:   if isAdmin() || ownsEmail(resource.data.clientEmail);
      allow create: if isSignedIn()
                    && request.resource.data.clientEmail == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    match /stockNotifications/{id} {
      allow read:   if isAdmin() || ownsEmail(resource.data.clientEmail);
      allow create: if isSignedIn()
                    && request.resource.data.clientEmail == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    match /verificationCodes/{phone} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
